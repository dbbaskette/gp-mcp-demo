#!/bin/sh
# DEPRECATED: use ./reset-demo-state.sh at the repo root. This wrapper exists
# for backward compatibility; it just delegates to the repo-level reset.

set -eu

SCRIPT="$0"
while [ -L "$SCRIPT" ]; do
  LINK="$(readlink "$SCRIPT")"
  case "$LINK" in
    /*) SCRIPT="$LINK" ;;
    *)  SCRIPT="$(dirname "$SCRIPT")/$LINK" ;;
  esac
done
REPO_ROOT="$(cd "$(dirname "$SCRIPT")/.." && pwd -P)"
exec "$REPO_ROOT/reset-demo-state.sh" "$@"
