{
    admin off
}

localhost {
    tls /certs/localhost+1.pem /certs/localhost+1-key.pem

    # MCP server endpoints (path preserved — MCP listens at /mcp)
    @mcp path /mcp /mcp/* /.well-known/oauth-protected-resource
    handle @mcp {
        reverse_proxy mcp:8080 {
            header_down WWW-Authenticate "http://localhost" "https://localhost"
        }
    }

    # data-chat SPA + API, reachable at /chat/* (backend sees /)
    handle_path /chat/* {
        reverse_proxy data-chat:8080
    }

    # Everything else → FeauxAuth (admin UI, /oauth/*, OIDC discovery, JWKS)
    handle {
        reverse_proxy feauxauth:8080
    }
}
