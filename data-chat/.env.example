# Copy to data-chat/.env (git-ignored) and fill in whichever keys you have.
# Missing keys => that provider is silently dropped from the model picker.

# ---- API keys (any combination; leave blank to hide that provider) ----
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- Model selection (shown in the UI picker) ----
# Change and restart data-chat to swap models — no rebuild needed.
OPENAI_MODEL=gpt-5-nano-2025-08-07
# GPT-5 family (gpt-5, gpt-5-mini, gpt-5-nano) only accepts temperature=1.
# Older models like gpt-4o-mini still accept 0.0–2.0.
OPENAI_TEMPERATURE=1

ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_TEMPERATURE=0.7

GEMINI_MODEL=gemini-3-flash-preview
GEMINI_TEMPERATURE=0.7

# ---- LM Studio (optional, OpenAI-compatible local inference) ----
# Leave LMSTUDIO_BASE_URL blank to disable.
# On macOS/Windows, host.docker.internal reaches the host automatically.
# On Linux, docker-compose.yml maps it via extra_hosts.
LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1
LMSTUDIO_API_KEY=lm-studio
# Comma-separated list. Each entry shows up as its own option in the UI picker.
# Example: LMSTUDIO_MODEL=google/gemma-4-31b,qwen/qwen3.5-9b
LMSTUDIO_MODEL=
LMSTUDIO_TEMPERATURE=0.7
